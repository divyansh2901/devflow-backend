// prisma => ORM (object relational mapper)


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  projects Project[] // one user -> many Projects
  sessions Session[]
}

model Project {
  id Int @id @default(autoincrement())
  name String
  description String?
  techStack String?
  createdAt DateTime @default(now())

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions Session[]
}

// cascade => delete user -> deletes all projects


model Session {
  id Int @id @default(autoincrement())
  topicWorked String
  duration Int
  notes String?
  createdAt DateTime @default(now())

  projectId Int
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}




